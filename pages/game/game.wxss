.stage {
  width: 100vw; height: 100vh;
  position: relative; overflow: hidden;
}

/* ===== 背景图 ===== */
.bg-img {
  position: absolute;
  top: 0; left: 0; width: 100%; height: 100%;
  z-index: 0;
}

/* 背景图淡入动画 */
.bg-fade-in { animation: bgFadeIn 0.8s ease-in-out; }
.bg-fade-out { opacity: 0; }
@keyframes bgFadeIn {
  from { opacity: 0; transform: scale(1.02); }
  to   { opacity: 1; transform: scale(1); }
}

/* ===== 情绪滤镜/暗角 ===== */
.mood-layer {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 1;
  pointer-events: none;
  transition: all 0.6s ease;
}
.mood-layer.angry {
  background: radial-gradient(circle at center, transparent 30%, rgba(120, 20, 20, 0.45) 100%);
  box-shadow: inset 0 0 120rpx rgba(180, 40, 40, 0.35);
}
.mood-layer.sad {
  background: radial-gradient(circle at center, transparent 40%, rgba(20, 35, 70, 0.55) 100%);
  filter: saturate(0.75) brightness(0.85);
}
.mood-layer.shock {
  background: radial-gradient(circle at center, transparent 20%, rgba(40, 20, 80, 0.5) 100%);
  box-shadow: inset 0 0 100rpx rgba(120, 80, 200, 0.3);
}
.mood-layer.tense {
  background: radial-gradient(circle at center, transparent 35%, rgba(0, 0, 0, 0.55) 100%);
}
.mood-layer.warm {
  background: radial-gradient(circle at center, transparent 30%, rgba(180, 120, 40, 0.25) 100%);
}
.mood-layer.ending {
  background: radial-gradient(circle at center, transparent 10%, rgba(10, 20, 50, 0.7) 100%);
}

/* ===== 右上角按钮 ===== */
.top-btns {
  position: absolute;
  top: 20rpx; right: 20rpx;
  display: flex;
  gap: 16rpx;
  z-index: 100;
}
.mute-btn {
  width: 70rpx; height: 70rpx;
  background: rgba(0,0,0,0.5);
  border-radius: 50%;
  display: flex; justify-content: center; align-items: center;
  font-size: 32rpx;
  transition: background 0.3s ease;
}
.mute-btn:active {
  background: rgba(74,144,226,0.6);
}

/* ===== 立绘：优化显示清晰度与动画 ===== */
.char-area {
  position: absolute;
  left: 0; right: 0; bottom: 30vh;
  height: 55vh;
  display: flex; justify-content: center; align-items: flex-end;
  z-index: 5;
  pointer-events: none;
}

.char-wrapper {
  position: relative;
  width: 100%;
  height: 100%;
  display: flex; justify-content: center; align-items: flex-end;
}

.char-img {
  width: 100%;
  height: 100%;
  max-width: 80vw;
  max-height: 55vh;
  image-rendering: -webkit-optimize-contrast;
  filter: contrast(1.05) saturate(1.02);
  animation: charAppear 0.6s ease-out, charIdle 3.2s ease-in-out 0.6s infinite;
}

/* 人物出现动画 */
@keyframes charAppear {
  from { opacity: 0; transform: translateY(30rpx) scale(0.98); filter: blur(4rpx); }
  to   { opacity: 1; transform: translateY(0) scale(1); filter: blur(0); }
}

/* 人物待机轻微摆动：呼吸感 */
@keyframes charIdle {
  0%, 100% { transform: translateY(0) rotate(0deg); }
  33% { transform: translateY(-8rpx) rotate(0.4deg); }
  66% { transform: translateY(6rpx) rotate(-0.3deg); }
}

/* 人物情绪状态 */
.char-img.angry {
  filter: contrast(1.12) saturate(1.15) brightness(1.05) drop-shadow(0 0 20rpx rgba(255, 60, 60, 0.5));
  animation: charAppear 0.6s ease-out, charAngry 0.5s ease-in-out 0.6s infinite;
}
.char-img.sad {
  filter: saturate(0.75) brightness(0.85) contrast(0.95);
  transform-origin: bottom center;
}
.char-img.shock {
  animation: charAppear 0.6s ease-out, charShock 0.6s ease-in-out 0.6s infinite;
}

@keyframes charAngry {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-4rpx); }
  75% { transform: translateX(4rpx); }
}
@keyframes charShock {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.015); }
}

/* 人物淡出动画 */
.char-fade-out {
  animation: charFadeOut 0.4s ease-in forwards;
}
@keyframes charFadeOut {
  from { opacity: 1; transform: translateY(0); }
  to   { opacity: 0; transform: translateY(-20rpx); }
}

/* ===== 场景标题：改进显示 ===== */
.scene-title {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  background: rgba(0,0,0,0.55);
  color: #fff;
  z-index: 50;
  animation: sceneTitleFade 1.2s ease-in-out;
}

.scene-title-main {
  font-size: 64rpx; font-weight: bold; letter-spacing: 12rpx;
  text-shadow: 0 0 30rpx rgba(255,255,255,0.3);
  animation: titleSlideIn 0.8s ease-out;
}
.scene-title-sub {
  font-size: 30rpx; margin-top: 20rpx; opacity: 0.85;
  letter-spacing: 4rpx;
  animation: titleSubSlideIn 1s ease-out;
}

@keyframes sceneTitleFade {
  from { opacity: 0; }
  to   { opacity: 1; }
}
@keyframes titleSlideIn {
  from { opacity: 0; transform: translateY(-40rpx); letter-spacing: 30rpx; }
  to   { opacity: 1; transform: translateY(0); }
}
@keyframes titleSubSlideIn {
  0%   { opacity: 0; transform: translateY(20rpx); }
  40%  { opacity: 0; transform: translateY(20rpx); }
  100% { opacity: 0.85; transform: translateY(0); }
}

/* ===== 对话框：改进动画 ===== */
.dialog-box {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  min-height: 30vh;
  background: linear-gradient(180deg, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.92) 40%);
  padding: 60rpx 50rpx 40rpx;
  box-sizing: border-box;
  z-index: 10;
  animation: dialogSlideUp 0.4s ease-out;
}

@keyframes dialogSlideUp {
  from { opacity: 0; transform: translateY(60rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.name-wrap {
  position: absolute;
  top: -60rpx; left: 50rpx;
  display: flex; flex-direction: column; align-items: flex-start;
}
.role-tag {
  background: #d9534f; color: #fff;
  font-size: 22rpx; padding: 4rpx 16rpx;
  border-radius: 6rpx 6rpx 0 0;
  letter-spacing: 2rpx;
}
.name-tag {
  background: #2c7be5; color: #fff;
  font-size: 32rpx; padding: 10rpx 30rpx;
  border-radius: 0 8rpx 8rpx 8rpx;
  font-weight: bold;
}

.dialog-text {
  color: #fff; font-size: 32rpx; line-height: 1.8;
  margin-top: 20rpx; min-height: 150rpx;
  margin-bottom: 80rpx;
}

/* 继续按钮 */
.next-btn {
  position: absolute;
  right: 40rpx; bottom: 30rpx;
  padding: 18rpx 50rpx;
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  color: #fff; font-size: 32rpx; font-weight: bold;
  letter-spacing: 4rpx; border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.5);
  display: flex; align-items: center; gap: 12rpx;
  animation: pulse 1.8s ease-in-out infinite, btnFadeIn 0.4s ease-out;
}
.next-btn:active { transform: scale(0.96); background: #1a5cb8; }
.next-arrow { font-size: 24rpx; animation: arrowMove 1s ease-in-out infinite; }

@keyframes pulse {
  0%, 100% { box-shadow: 0 4rpx 16rpx rgba(74, 144, 226, 0.5); transform: scale(1); }
  50%      { box-shadow: 0 4rpx 30rpx rgba(74, 144, 226, 0.95); transform: scale(1.02); }
}
@keyframes arrowMove {
  0%, 100% { transform: translateX(0); }
  50%      { transform: translateX(8rpx); }
}
@keyframes btnFadeIn {
  from { opacity: 0; transform: translateX(30rpx); }
  to   { opacity: 1; transform: translateX(0); }
}

/* ===== 选择框：改进动画 ===== */
.choice-box {
  position: absolute;
  top: 20%; left: 8%; right: 8%;
  display: flex; flex-direction: column; align-items: center;
  max-height: 65vh; overflow-y: auto;
  z-index: 20;
  animation: choiceFadeIn 0.5s ease-out;
}

@keyframes choiceFadeIn {
  from { opacity: 0; transform: translateY(40rpx); }
  to   { opacity: 1; transform: translateY(0); }
}

.choice-prompt {
  color: #e8f0ff; font-size: 32rpx;
  margin-bottom: 40rpx;
  text-shadow: 0 2rpx 10rpx rgba(0,0,0,0.9);
  text-align: center;
}

.choice-item {
  width: 100%; padding: 28rpx 40rpx;
  background: rgba(15, 20, 45, 0.92);
  border: 2rpx solid #4a90e2;
  border-radius: 16rpx;
  color: #fff; font-size: 28rpx;
  text-align: center; margin-bottom: 20rpx;
  transition: all 0.25s ease;
  box-sizing: border-box;
  line-height: 1.5;
  backdrop-filter: blur(10rpx);
}

.choice-item:active {
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  transform: scale(0.98);
  box-shadow: 0 4rpx 20rpx rgba(74,144,226,0.6);
}

/* ===== AI 输入框 ===== */
.ai-input-box {
  position: absolute;
  left: 6%; right: 6%; top: 18%;
  background: rgba(10, 15, 35, 0.96);
  border: 2rpx solid #4a90e2;
  border-radius: 20rpx;
  padding: 35rpx 40rpx;
  box-shadow: 0 8rpx 50rpx rgba(74,144,226,0.45);
  box-sizing: border-box;
  z-index: 30;
  animation: aiFadeIn 0.5s ease-out;
  backdrop-filter: blur(20rpx);
}

@keyframes aiFadeIn {
  from { opacity: 0; transform: scale(0.95); }
  to   { opacity: 1; transform: scale(1); }
}

.ai-title { display: flex; align-items: center; margin-bottom: 16rpx; }
.ai-icon { font-size: 36rpx; margin-right: 12rpx; }
.ai-target {
  color: #6bb5ff; font-size: 28rpx;
  font-weight: bold; letter-spacing: 2rpx;
}
.ai-prompt {
  color: #e8f0ff; font-size: 28rpx;
  line-height: 1.6; margin-bottom: 24rpx;
}
.ai-textarea {
  width: 100%; min-height: 180rpx;
  background: rgba(255,255,255,0.06);
  border: 2rpx solid rgba(74,144,226,0.5);
  border-radius: 12rpx; padding: 24rpx;
  color: #fff; font-size: 28rpx;
  box-sizing: border-box; line-height: 1.6;
}
.ai-placeholder { color: rgba(255,255,255,0.4); font-size: 26rpx; }
.ai-tip { color: #888; font-size: 22rpx; margin-top: 12rpx; text-align: right; }
.ai-btn-row { display: flex; justify-content: space-between; margin-top: 28rpx; gap: 20rpx; }
.ai-btn-skip {
  flex: 1; background: rgba(255,255,255,0.08);
  color: #aaa; font-size: 28rpx;
  border-radius: 50rpx; height: 80rpx; line-height: 80rpx;
}
.ai-btn-submit {
  flex: 2;
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  color: #fff; font-size: 30rpx; font-weight: bold;
  border-radius: 50rpx; height: 80rpx; line-height: 80rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,144,226,0.5);
}
.ai-btn-skip:active { transform: scale(0.96); }
.ai-btn-submit:active { transform: scale(0.96); }

/* ===== AI Loading ===== */
.ai-loading {
  position: absolute; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75);
  display: flex; flex-direction: column;
  justify-content: center; align-items: center;
  z-index: 200;
  animation: loadingFadeIn 0.3s ease-out;
}

@keyframes loadingFadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.ai-loading-spinner {
  width: 100rpx; height: 100rpx;
  border: 8rpx solid rgba(74,144,226,0.2);
  border-top-color: #6bb5ff;
  border-radius: 50%;
  animation: spin 0.9s linear infinite;
  margin-bottom: 30rpx;
  box-shadow: 0 0 30rpx rgba(74,144,226,0.4);
}

.ai-loading-text { color: #fff; font-size: 32rpx; letter-spacing: 6rpx; }

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== 结局 ===== */
.end-box {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  text-align: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 60rpx 160rpx;
  z-index: 60;
  background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.85) 100%);
  animation: endFadeIn 1.2s ease-in-out;
  box-sizing: border-box;
}

.end-scroll {
  width: 100%;
  max-height: 70vh;
}

.end-title {
  width: 100%;
  color: #fff; font-size: 44rpx;
  letter-spacing: 6rpx;
  white-space: pre-line; line-height: 1.7;
  text-shadow: 0 0 30rpx rgba(74,144,226,0.3);
  animation: endTitleGlow 2s ease-in-out;
  padding-bottom: 40rpx;
}

.end-btn {
  position: absolute;
  bottom: 60rpx;
  width: 300rpx;
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  color: #fff;
  font-weight: bold;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 20rpx rgba(74,144,226,0.5);
  animation: endBtnFadeIn 1.5s ease-out;
}
.end-btn:active { transform: scale(0.96); }

/* 分享海报按钮 */
.poster-btn {
  position: absolute;
  bottom: 160rpx;
  width: 300rpx;
  background: transparent;
  border: 2rpx solid rgba(74,144,226,0.6);
  color: #6bb5ff;
  font-weight: bold;
  border-radius: 50rpx;
  font-size: 28rpx;
}
.poster-btn:active { transform: scale(0.96); background: rgba(74,144,226,0.1); }

/* 海报浮层 */
.poster-overlay {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.85);
  z-index: 200;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  animation: fadeIn 0.3s ease-out;
}

.poster-canvas {
  width: 600rpx;
  height: 900rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.5);
}

.poster-actions {
  margin-top: 40rpx;
  display: flex;
  gap: 30rpx;
}

.poster-action-btn {
  width: 260rpx;
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  color: #fff;
  font-weight: bold;
  border-radius: 50rpx;
  font-size: 28rpx;
}
.poster-action-btn.secondary {
  background: rgba(255,255,255,0.1);
  border: 2rpx solid rgba(255,255,255,0.3);
  color: #fff;
}
.poster-action-btn:active { transform: scale(0.96); }

@keyframes endTitleGlow {
  from { opacity: 0; text-shadow: 0 0 0 rgba(74,144,226,0); }
  to   { opacity: 1; text-shadow: 0 0 30rpx rgba(74,144,226,0.3); }
}

@keyframes endBtnFadeIn {
  0%, 60% { opacity: 0; transform: translateY(20rpx); }
  100%   { opacity: 1; transform: translateY(0); }
}

/* ===== 淡入淡出通用动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to   { opacity: 1; transform: none; }
}

/* ===== 历史记录面板 ===== */
.history-panel {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.75);
  z-index: 150;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 50rpx;
  box-sizing: border-box;
  animation: fadeIn 0.3s ease-out;
}

.history-scroll {
  width: 100%;
  max-height: 75vh;
  background: rgba(15, 20, 40, 0.96);
  border: 2rpx solid rgba(74,144,226,0.5);
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
}

.history-title {
  color: #6bb5ff;
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
  letter-spacing: 4rpx;
}

.history-item {
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.08);
}

.history-name {
  color: #4a90e2;
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.history-text {
  color: #e8f0ff;
  font-size: 28rpx;
  line-height: 1.6;
}

.history-empty {
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
  text-align: center;
  padding: 40rpx 0;
}
