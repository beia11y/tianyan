.menu {
  height: 100vh; 
  display: flex; 
  flex-direction: column;
  justify-content: center; 
  align-items: center;
  background: linear-gradient(180deg,#0a0e1a,#1a2540);
  padding: 0 60rpx;
}

.title { 
  font-size: 120rpx; 
  color: #fff; 
  letter-spacing: 40rpx; 
  font-weight: bold; 
}

.subtitle { 
  color: #8aa; 
  margin: 30rpx 0 80rpx; 
  letter-spacing: 8rpx; 
  font-size: 28rpx;
}

.btn { 
  width: 400rpx; 
  margin-bottom: 24rpx; 
  background: rgba(74,144,226,0.2); 
  color: #fff;
  border: 2rpx solid #4a90e2;
  border-radius: 50rpx;
}

.btn.primary {
  background: linear-gradient(135deg, #4a90e2, #2c7be5);
  border: none;
  font-weight: bold;
}

.btn.small {
  width: 380rpx;
  font-size: 26rpx;
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.2);
  color: #ddd;
}

.divider {
  width: 60%;
  height: 2rpx;
  background: rgba(255,255,255,0.15);
  margin: 40rpx 0 30rpx;
}

.tip {
  color: #888;
  font-size: 22rpx;
  margin-top: 30rpx;
  text-align: center;
  line-height: 1.6;
}
